# ============================================================
# SymptomAnalyzer — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Neon PostgreSQL connection string (or any pg-compatible URL)
DATABASE_URL=postgresql://user:password@host/dbname

# ── Authentication ────────────────────────────────────────────
# Used for Express session signing — generate a random string
SESSION_SECRET=change_me_to_a_long_random_secret

# ⚠️  REPLIT AUTH (remove these when you replace auth) ──────────
# REPLIT_DOMAINS=your-app.replit.app
# REPL_ID=your-repl-id
# ISSUER_URL=https://replit.com/oidc

# ── Replacement Auth (e.g. Clerk, Auth.js, or custom JWT) ─────
# CLERK_SECRET_KEY=sk_live_...
# NEXTAUTH_SECRET=...
# NEXTAUTH_URL=http://localhost:3000

# ── OpenAI ───────────────────────────────────────────────────
# Required for AI-powered diagnostic analysis (GPT-4o)
OPENAI_API_KEY=sk-...

# ── Paystack ─────────────────────────────────────────────────
# Required for subscription payment processing
PAYSTACK_SECRET_KEY=sk_live_...
# Public key used on the frontend to load Paystack popup
PAYSTACK_PUBLIC_KEY=pk_live_...

# ── SendGrid ─────────────────────────────────────────────────
# Required for email notifications (report alerts)
SENDGRID_API_KEY=SG....
# Verified sender email address in SendGrid
SENDGRID_FROM_EMAIL=you@yourdomain.com
# Admin email to receive report notifications
ADMIN_EMAIL=admin@yourdomain.com

# ── App ──────────────────────────────────────────────────────
# Node environment
NODE_ENV=development
# Server port
PORT=5000
